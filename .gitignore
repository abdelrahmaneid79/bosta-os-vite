# self-hosted OCR wasm/worker — reproduced from node_modules by
# scripts/setup-ocr-assets.mjs at build time (npm install always runs), so kept
# out of git. The LANGUAGE DATA (*.traineddata.gz) IS committed (below) so the
# build never needs network — the only asset that would otherwise be downloaded.
public/ocr/*.wasm
public/ocr/worker.min.js
public/ocr/tesseract-core*.js
